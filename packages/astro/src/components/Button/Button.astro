---
import { button, loadingContent, spinnerWrapper, textWrapper } from "./button.css";
import type { ButtonProps } from "./Button.types";
import { palettes } from "../../theme/palette/palette.css";

const {
  as: Tag = "button",
  class: classList,
  type = "button",
  disabled,
  shape,
  fill,
  size,
  block,
  palette,
  loading,
  loadingText,
  loadingSpinner,
  spinnerPlacement = "start",
  ...props
}: ButtonProps = Astro.props;
---

<Tag class:list={[
  button({ shape, fill, size, block }),
  palette && palettes[palette],
  classList,
]} {type} data-loading={loading} disabled={disabled || loading} {...props}>
  {loading ?
    (<span class={loadingContent}>
      {loadingText ? (
        <>
          {spinnerPlacement === "start" && (loadingSpinner ?? <span>[]</span>)}
          {loadingText}
          {spinnerPlacement === "end" && (loadingSpinner ?? <span>[]</span>)}
        </>) : (
        <>
          <div class={spinnerWrapper}>
            {loadingSpinner ?? <span>[]</span>}
          </div>
          <span class={textWrapper}>
            <slot />
          </span>
        </>)}
    </span>) :
    <slot />}
</Tag>
